      Queue Size: 10
      Selectable: true
      Size (Pixels): 4
      Size (m): 0.05000000074505806
      Style: Points
      Topic: /iros_run_replay/geometry_points
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: false
      Value: true
    - Class: rviz/Marker
      Enabled: false
