<launch>
  <arg name="gaussians_path" default="$(env HOME)/Documents/IROS_2026/GaussianSpace/default_loc/gaussians_latest.txt" />
  <arg name="viewpoint_samples" default="25" />
  <arg name="fov_deg" default="70.0" />
  <arg name="near_clip" default="0.5" />
  <arg name="far_clip" default="5.0" />
  <arg name="update_rate" default="2.0" />
  <arg name="frame_id" default="odom_local_ned" />
  <arg name="root_frame" default="world" />

  <node pkg="controller" type="viewpoint_visualization_node.py" name="viewpoint_visualization" output="screen">
    <rosparam file="$(find controller)/config/controller.yaml" command="load" />
    <param name="frame_id" value="$(arg frame_id)" />
    <param name="root_frame" value="$(arg root_frame)" />
    <param name="file_paths/gaussians_path" value="$(arg gaussians_path)" />
    <param name="viewpoints/num_samples" value="$(arg viewpoint_samples)" />
    <param name="viewpoints/fov_deg" value="$(arg fov_deg)" />
    <param name="viewpoints/near_clip" value="$(arg near_clip)" />
    <param name="viewpoints/far_clip" value="$(arg far_clip)" />
    <param name="update_rate_hz" value="$(arg update_rate)" />
  </node>

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find controller)/config/viewpoint_visualization.rviz" />
</launch>
